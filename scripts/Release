#!/usr/local/bin/java --source 25

//================================================================================
// CONVENTIONS
//================================================================================
// Release commits: :bookmark: module@version, module2@version2, ...

import java.io.PrintStream;
import java.io.PrintWriter;
import java.io.StringWriter;
import java.nio.charset.StandardCharsets;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.*;
import java.util.concurrent.CompletableFuture;
import java.util.concurrent.CompletionException;
import java.util.stream.Collectors;

//@formatter:off
public class Release {
    static final Logger LOGGER = new Logger();
    static LogLevel LOG_LEVEL = LogLevel.WARN;
    static boolean DRY_RUN = false;

    static final Path GRADLEW = Paths.get(os() == OS.Windows ? "gradlew.bat" : "gradlew");

    static void main(String[] args) {
        parseArgs(args);
        run();
    }

    static void run() {
        try {
            Commit head = new GitHeadCommitCommand().exec();
            LOGGER.debug("Head commit: [%s] %s".formatted(head.hash(), head.header()));

            List<ModuleRelease> releases = ModuleRelease.parseAll(head);
            if (releases.isEmpty()) {
                System.out.println("✅ No modules to release.");
                return;
            }

            if (DRY_RUN) {
                System.out.println("Modules to release:");
                releases.forEach(r -> System.out.printf("  - %s@%s%n",r.module(), r.version()));
                return;
            }

            releases.forEach(Release::release);
            System.out.println("🎉 Release process completed.");
        } catch (Exception ex) {
            LOGGER.error(ex);
        }
    }

    static void release(ModuleRelease module) {
        try {
            System.out.printf("🚀 Releasing: %s@%s%n", module.module(), module.version());
            new GradlePublishCommand(module.module()).exec();
        } catch (Exception ex) {
            LOGGER.error("❌ Failed to release module: " + module.module());
            LOGGER.error(ex);
        }
    }

    static void parseArgs(String[] args) {
        NavigableSet<String> argSet = new TreeSet<>(Arrays.asList(args));
        if (args.length == 0 || argSet.contains("--help") || argSet.contains("-h")) {
            printHelp();
            System.exit(0);
        }
        if (argSet.contains("--dry-run")) DRY_RUN = true;

        String logArg = argSet.ceiling("--log-level=");
        if (logArg != null && logArg.startsWith("--log-level=")) {
            String level = logArg.split("=", 2)[1];
            LOG_LEVEL = LogLevel.valueOf(level.toUpperCase());
        }
    }

    static void printHelp() {
        String message = """
            This script publishes modules to Maven Central.
            Reads the latest commit (expected to be a release commit marked by :bookmark:),
            parses the released modules and versions from the header, and runs the Gradle
            publish task for each.

            ** Arguments **
              • --help, -h          : Prints this help message.
              • --dry-run           : Prints the modules that would be released without publishing.
              • --log-level=<level> : Sets log verbosity. Levels: TRACE, DEBUG, INFO, WARN, ERROR (default: WARN)
            """;
        System.out.println(message);
    }

    //================================================================================
    // COMMANDS
    //================================================================================

    static class GitHeadCommitCommand extends Command<Commit> {
        @Override
        protected String[] args() {
            return new String[]{"git", "log", "-1", "--pretty=format:%at%n%h%n%s"};
        }

        @Override
        protected Commit parse(String output) {
            String[] lines = output.trim().split("\n");
            long timestamp = Long.parseLong(lines[0].trim());
            String hash = lines[1].trim();
            String header = lines[2].trim();
            return new Commit(timestamp, hash, header);
        }
    }

    static class GradlePublishCommand extends Command<Void> {
        private final String module;

        GradlePublishCommand(String module) {
            this.module = module;
        }

        @Override
        protected String[] args() {
            return new String[]{
                GRADLEW.toAbsolutePath().toString(),
                ":%s:publishAndReleaseToMavenCentral".formatted(module)
            };
        }

        @Override
        protected Void parse(String output) {return null;}

        @Override
        public Void exec() throws CommandExecutionException {
            // inheritIO streams gradle output directly to the console in real-time
            try {
                Process proc = new ProcessBuilder(args())
                    .inheritIO()
                    .start();
                int exitCode = proc.waitFor();
                if (exitCode != 0)
                    throw new CommandExecutionException(
                        new RuntimeException("Gradle publish failed (exit %d) for module: %s".formatted(exitCode, module))
                    );
                return null;
            } catch (CommandExecutionException ex) {
                throw ex;
            } catch (Exception ex) {
                throw new CommandExecutionException(ex);
            }
        }
    }

    static abstract class Command<T> {
        protected abstract String[] args();
        protected abstract T parse(String output);

        /// For fire and forget commands with no output/parsing
        public static void quickExec(String... args) {
            new Command<Void>() {
                @Override protected String[] args() {return args;}
                @Override protected Void parse(String output) {return null;}
            }.exec();
        }

        public T exec() throws CommandExecutionException {
            try {
                LOGGER.trace("Executing command %s: %s".formatted(getClass().getSimpleName(), Arrays.toString(args())));
                Process proc = new ProcessBuilder(args())
                    .redirectErrorStream(true)
                    .start();

                CompletableFuture<String> outputFuture = CompletableFuture.supplyAsync(() -> {
                    try {
                        return new String(proc.getInputStream().readAllBytes(), StandardCharsets.UTF_8);
                    } catch (Exception ex) {
                        throw new CompletionException(ex);
                    }
                });

                int exitCode = proc.waitFor();
                String output;
                try {
                    output = outputFuture.join();
                } catch (CompletionException ex) {
                    throw new CommandExecutionException(ex.getCause());
                }

                if (exitCode != 0) {
                    throw new CommandExecutionException(
                        new RuntimeException("Command failed (exit %d): %s".formatted(exitCode, output))
                    );
                }

                return parse(output);
            } catch (CommandExecutionException ex) {
                throw ex;
            } catch (Exception ex) {
                throw new CommandExecutionException(ex);
            }
        }
    }

    static class CommandExecutionException extends RuntimeException {
        public CommandExecutionException(Throwable cause) {
            super(cause);
        }
    }

    //================================================================================
    // MODEL
    //================================================================================

    record Commit(long timestamp, String hash, String header) {}

    record ModuleRelease(String module, String version) {
        public static List<ModuleRelease> parseAll(Commit releaseCommit) {
            List<ModuleRelease> releases = new ArrayList<>();
            String header = releaseCommit.header().replace(":bookmark:", "").trim();
            for (String token : header.split(",")) {
                String[] parts = token.trim().split("@");
                if (parts.length == 2) {
                    releases.add(new ModuleRelease(parts[0].trim(), parts[1].trim()));
                    continue;
                }
                LOGGER.error("Invalid release token: " + token);
            }
            return releases;
        }
    }

    //================================================================================
    // UTILS
    //================================================================================

    enum OS {Windows, Linux, MacOS, Other}

    static OS os() {
        String name = System.getProperty("os.name");
        return switch (name) {
            case String s when s.toLowerCase().contains("win") -> OS.Windows;
            case String s when s.contains("nix") || s.contains("nux") -> OS.Linux;
            case String s when s.toLowerCase().contains("mac") -> OS.MacOS;
            default -> OS.Other;
        };
    }

    static class Logger {
        public void trace(String message) {LogLevel.TRACE.print(message);}
        public void debug(String message) {LogLevel.DEBUG.print(message);}
        public void info(String message) {LogLevel.INFO.print(message);}
        public void warn(String message) {LogLevel.WARN.print(message);}
        public void error(String message) {LogLevel.ERROR.print(message);}
        public void error(Throwable t) {
            StringWriter sw = new StringWriter();
            t.printStackTrace(new PrintWriter(sw, true));
            error(sw.toString());
        }
    }

    enum LogLevel {
        TRACE, DEBUG, INFO,
        WARN(System.err),
        ERROR(System.err);

        final PrintStream stream;
        LogLevel() {this.stream = System.out;}
        LogLevel(PrintStream stream) {this.stream = stream;}

        void print(String message) {
            if (LOG_LEVEL != null && this.ordinal() >= LOG_LEVEL.ordinal())
                stream.printf("%tT - [%s]: %s%n", System.currentTimeMillis(), name(), message);
        }
    }
}
